(kicad_pcb (version 20221018) (generator pcbnew)

  (general
    (thickness 1.6)
  )

  (net 0 "")
  (net 1 "GND")
  (net 2 "VCC")
  (net 3 "/SDA")
  (net 4 "/SCL")

  (gr_line (start 100 80) (end 140 80) (layer "Edge.Cuts") (width 0.05))
  (gr_line (start 140 80) (end 140 110) (layer "Edge.Cuts") (width 0.05))
  (gr_line (start 140 110) (end 100 110) (layer "Edge.Cuts") (width 0.05))
  (gr_line (start 100 110) (end 100 80) (layer "Edge.Cuts") (width 0.05))

  (segment (start 110 90) (end 125 90) (width 0.25) (layer "F.Cu") (net 2))
  (segment (start 125 90) (end 130 95) (width 0.25) (layer "F.Cu") (net 2))
  (segment (start 110 95) (end 120 95) (width 0.25) (layer "F.Cu") (net 1))
  (segment (start 120 95) (end 120 100) (width 0.25) (layer "F.Cu") (net 1))
  (segment (start 110 100) (end 125 100) (width 0.15) (layer "F.Cu") (net 3))
  (segment (start 125 100) (end 130 100) (width 0.15) (layer "F.Cu") (net 3))
  (segment (start 110 105) (end 125 105) (width 0.15) (layer "F.Cu") (net 4))
  (segment (start 125 105) (end 130 105) (width 0.15) (layer "F.Cu") (net 4))
  (segment (start 120 100) (end 120 105) (width 0.25) (layer "B.Cu") (net 1))
  (segment (start 130 95) (end 135 95) (width 0.25) (layer "F.Cu") (net 2))

  (via (at 120 100) (size 0.8) (drill 0.4) (net 1))
  (via (at 130 95) (size 0.8) (drill 0.4) (net 2))

  (footprint "Resistor_SMD:R_0402_1005Metric"
    (layer "F.Cu")
    (at 110 90)
    (property "Reference" "R1")
    (property "Value" "10k")
    (pad "1" smd roundrect (at -0.5 0) (size 0.5 0.5) (net 2))
    (pad "2" smd roundrect (at 0.5 0) (size 0.5 0.5) (net 0))
    (fp_line (start -1 -0.5) (end 1 -0.5) (layer "F.CrtYd") (width 0.05))
    (fp_line (start 1 -0.5) (end 1 0.5) (layer "F.CrtYd") (width 0.05))
    (fp_line (start 1 0.5) (end -1 0.5) (layer "F.CrtYd") (width 0.05))
    (fp_line (start -1 0.5) (end -1 -0.5) (layer "F.CrtYd") (width 0.05))
  )

  (footprint "Resistor_SMD:R_0402_1005Metric"
    (layer "F.Cu")
    (at 110 95)
    (property "Reference" "R2")
    (property "Value" "4.7k")
    (pad "1" smd roundrect (at -0.5 0) (size 0.5 0.5) (net 1))
    (pad "2" smd roundrect (at 0.5 0) (size 0.5 0.5) (net 0))
  )

  (footprint "Capacitor_SMD:C_0402_1005Metric"
    (layer "F.Cu")
    (at 110 100)
    (property "Reference" "C1")
    (property "Value" "100nF")
    (pad "1" smd roundrect (at -0.5 0) (size 0.5 0.5) (net 3))
    (pad "2" smd roundrect (at 0.5 0) (size 0.5 0.5) (net 0))
  )

  (footprint "Package_SO:SOIC-8_3.9x4.9mm_P1.27mm"
    (layer "F.Cu")
    (at 130 100)
    (property "Reference" "U1")
    (property "Value" "ATtiny85")
    (pad "1" smd rect (at -2.7 -1.905) (size 1.5 0.6) (net 2))
    (pad "2" smd rect (at -2.7 -0.635) (size 1.5 0.6) (net 3))
    (pad "3" smd rect (at -2.7 0.635) (size 1.5 0.6) (net 4))
    (pad "4" smd rect (at -2.7 1.905) (size 1.5 0.6) (net 1))
    (pad "5" smd rect (at 2.7 1.905) (size 1.5 0.6) (net 0))
    (pad "6" smd rect (at 2.7 0.635) (size 1.5 0.6) (net 0))
    (pad "7" smd rect (at 2.7 -0.635) (size 1.5 0.6) (net 0))
    (pad "8" smd rect (at 2.7 -1.905) (size 1.5 0.6) (net 2))
    (fp_line (start -2 -2.5) (end 2 -2.5) (layer "F.CrtYd") (width 0.05))
    (fp_line (start 2 -2.5) (end 2 2.5) (layer "F.CrtYd") (width 0.05))
    (fp_line (start 2 2.5) (end -2 2.5) (layer "F.CrtYd") (width 0.05))
    (fp_line (start -2 2.5) (end -2 -2.5) (layer "F.CrtYd") (width 0.05))
  )

)
